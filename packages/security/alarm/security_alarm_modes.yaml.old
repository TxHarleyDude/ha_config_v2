automation:
  - alias: "Arrived Home - Disarm Alarm"
    id: "arrived_home_disarm_alarm"
    mode: single
    trigger:
      - trigger: state
        entity_id: group.people_home
        to: "on"
    condition:
      - condition: state
        entity_id: group.people_home
        state: "on"
    action:
      - action: alarm_control_panel.alarm_disarm
        target:
          entity_id: alarm_control_panel.alarmo

  - alias: "Away Mode - Set Alarm"
    id: "away_mode_set_Alarm"
    mode: single
    trigger:
      - trigger: state
        entity_id: group.people_home
        to: "off"
        for:
          hours: 0
          minutes: 0    # added 2nd zone for near home to delay away mode
          seconds: 0
    condition:
      - condition: state
        entity_id: group.people_home
        state: "off"
      - condition: state
        entity_id: alarm_control_panel.alarmo
        state: "disarmed"
    action:
      - action: alarm_control_panel.alarm_arm_away
        target:
          entity_id: alarm_control_panel.alarmo

  - alias: Bedtime - Arm Night
    id: "bedtime_alarm_night"
    trigger:
      - trigger: state
        entity_id: input_boolean.bedtime
        to: "on"
        for:
          hours: 0
          minutes: 2
          seconds: 0
    condition:
      - condition: state
        entity_id: group.people_home
        state: "on"
    action:
      - action: alarm_control_panel.alarm_arm_night
        target:
          entity_id: alarm_control_panel.alarmo

